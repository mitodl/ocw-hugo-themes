    "jquery": "^3.7.1",
    "lodash.has": "^4.5.2",
    "lodash.uppercase": "^4.3.0",
    "mathjax": "^4.0.0",
    "nanogallery2": "^2.4.2",
    "offcanvas-bootstrap": "^2.5.2",
    "pdfobject": "^2.2.8",
    "popper.js": "^1.16.1",
    "posthog-js": "^1.225.0",
    "promise-polyfill": "^8.3.0",
    "ramda": "^0.32.0",
    "react": "^18.2.14",
    "react-bootstrap": "^2.0.0",
    "react-content-loader": "^7.0.0",
    "react-dom": "^18.2.14",
    "react-dotdotdot": "1.3.1",
    "react-infinite-scroller": "^1.2.6",
    "sass": "1.99.0",
    "tiny-invariant": "^1.3.3",
