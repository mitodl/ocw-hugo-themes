{
  "name": "ocw-hugo-themes",
  "version": "1.148.1",
  "description": "A Hugo theme for building OCW websites",
  "repository": "mitodl/ocw-hugo-themes",
  "main": "base-theme/assets/index.js",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "lint": "DISABLE_V8_COMPILE_CACHE=1 eslint $PROJECT_CWD/'**/*.{js,jsx,ts,tsx}'",
    "start": "NODE_ENV=development ts-node ./package_scripts/start.ts",
    "start:webpack": "yarn with-env --dev -- webpack --config ./base-theme/assets/webpack/webpack.dev.ts --stats-children",
    "start:www": "echo This command has been removed. Use `yarn start www` instead.",
    "start:course": "echo This command has been removed. Use `yarn start course` instead.",
    "subset-fonts": "ts-node ./package_scripts/subset-fonts.ts",
    "prebuild": "rimraf dist",
    "build": "yarn with-env -- ./package_scripts/build.sh",
    "build:githash": "mkdir -p base-theme/dist/static && git rev-parse HEAD > base-theme/dist/static/hash.txt",
    "build:hugo": "hugo -d ../dist -v",
    "build:hugo:debug": "hugo -d ../dist -v --templateMetrics --debug",
    "build:webpack": "cross-env NODE_ENV=production webpack --config base-theme/assets/webpack/webpack.prod.ts",
    "build:webpack:dev": "cross-env NODE_ENV=development WEBPACK_WATCH_MODE=false webpack --config base-theme/assets/webpack/webpack.dev.ts",
    "webpack:serve": "cross-env NODE_ENV=development webpack serve --config base-theme/assets/webpack/webpack.dev.ts",
    "webpack:stats": "NODE_ENV=production webpack --config base-theme/assets/webpack/webpack.prod.ts --profile --json > stats.json",
    "webpack:analyze": "webpack-bundle-analyzer stats.json dist",
    "fmt": "yarn fmt:check --write",
    "fmt:check": "LOG_LEVEL= prettier-eslint --list-different $PROJECT_CWD/'**/*.{js,jsx,ts,tsx,scss}'",
    "scss_lint": "node ./node_modules/sass-lint/bin/sass-lint.js --verbose --no-exit ./assets",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:verbose": "jest --verbose",
    "test:e2e": "yarn with-env --dev -- ./package_scripts/test_e2e.sh",
    "test:e2e:jest": "yarn jest --testPathIgnorePatterns='/node_modules/' --testPathPatterns='/tests-e2e/jest/'",
    "typecheck": "tsc --noEmit",
    "with-env": "ts-node ./package_scripts/with-env.ts"
  },
  "license": "BSD-3-CLAUSE",
  "resolutions": {
    "jquery": "3.7.1"
  },
  "browserslist": "> 0.25%, not dead",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mitodl/course-search-utils": "^2.3.3",
    "@mitodl/mit-learn-api-axios": "^2026.3.31",
    "@mitodl/smoot-design": "^6.0.1",
    "@mui/lab": "^7.0.0",
    "@mui/material": "^7.0.1",
    "@remixicon/react": "^4.6.0",
    "@sentry/browser": "^10.0.0",
    "@tanstack/react-query": "^5.66.0",
    "array-flat-polyfill": "^1.0.1",
    "bootstrap": "^4.3.1",
    "casual": "^1.6.2",
    "core-js": "^3.38.1",
    "es6-promise": "^4.2.8",
    "formik": "^2.4.6",
    "fuse.js": "^7.0.0",
