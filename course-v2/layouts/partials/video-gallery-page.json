{{- $ctx := . -}}
{{- $computed := dict -}}
{{- if isset .Params "videos" -}}
{{- $videos := slice -}}
{{- range $index, $uuid := .Params.videos.content -}}
{{- range $ctx.Site.Pages -}}
{{- if eq (replace .Params.uid "-" "") (replace $uuid "-" "") -}}
{{- $videos = $videos | append .Params -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $computed = merge $computed (dict "videos" $videos) -}}
{{- end -}}
{{- merge .Params $computed (dict "content" .Content) | jsonify (dict "noHTMLEscape" true "indent" "  ") -}}
