{{- $courseData := .Site.Data.course | default dict -}}
{{- $courseImageUrl := index (partial "course-image-url.html" .) 0 -}}
{{- $courseImageMetadata := index (partial "course-image-url.html" .) 1 -}}
{{- $instructors := slice -}}
{{- with $courseData.instructors -}}
{{- $instructors = partial "get_instructors.html" .content -}}
{{- end -}}
{{- $computed := dict "course_description_html" ($courseData.course_description | default "" | $.RenderString) "image_src" $courseImageUrl "course_image_metadata" $courseImageMetadata.Params "instructors" $instructors -}}
{{- merge $courseData $computed | jsonify (dict "noHTMLEscape" true "indent" "  ") -}}

